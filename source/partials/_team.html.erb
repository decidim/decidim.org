<div class="md:grid md:grid-cols-3 grid-cols-2 gap-8">
  <% data.association.each do |member| %>
    <% if member.type == type %>
      <div class="[perspective:1000px] cursor-pointer hover:shadow-lg transition-shadow duration-300" style="height:485px;" onclick="this.querySelector('.flip-inner').classList.toggle('rotate-y-180')">
        <div class="flip-inner relative rounded-lg w-full h-full transition-transform duration-500 [transform-style:preserve-3d]">
          <div class="flip-front absolute inset-0 flex flex-col gap-1 [backface-visibility:hidden]">
            <img src="<%= member.photo %>" alt="<%= member.name %>" class="w-96 h-96 object-cover rounded" />
            <p class="font-semibold"><%= member.name %></p>
            <p><%= t("team.members.#{member['key']}.role") %></p>
          </div>
          <div class="flip-back absolute inset-0 flex flex-col gap-3 p-4 bg-red-100 rounded shadow [backface-visibility:hidden] [transform:rotateY(180deg)]">
            <p class="text-sm"><%= t("team.members.#{member['key']}.bio") %></p>
            <% if member.linkedin_url && !member.linkedin_url.to_s.empty? %>
              <a href="<%= member.linkedin_url %>" target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-1 text-sm text-blue-600 hover:underline" onclick="event.stopPropagation()">
                <%= icon "ri-linkedin-box-fill", class: "w-4 h-4" rescue nil %>
                /LinkedIn
              </a>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
