---
nav: first-steps
description:
---

<section>
  <div class="container pt-10 pb-6 md:pt-16 md:pb-[6.25rem]">
    <div class="md:w-3/5 space-y-6">
      <h1 class="h1 md:whitespace-nowrap">
        <%= t("first-steps.title") %>
      </h1>
      <p class="par-xl">
        <%= t("first-steps.subtitle") %>
      </p>
      <div class="par-md">
        <%= t("first-steps.intro") %>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container flex flex-col md:flex-row justify-start items-stretch divide-y-2 md:divide-y-0 divide-gray-300 pb-6">
    <% data.first_steps.each do |item| %>
      <div class="flex flex-col md:border-l-2 border-gray-300 md:first:border-l-0 px-0 py-6 md:px-10 md:first:pl-0 md:py-0 w-full">
        <div class="flex items-center space-x-2">
          <%= icon item.icon, class: "w-6 h-6" %>
          <span class="font-semibold uppercase"><%= t("first-steps.#{item.pre}") %></span>
        </div>
        <h5 class="h5 mt-7"><%= t("first-steps.#{item.title}") %></h5>
        <p class="par-md max-w-prose text-gray-500 mt-4 mb-6"><%= t("first-steps.#{item.content}") %></p>
      </div>
    <% end %>
    </div>
</section>

<section>
  <div class="container space-y-6 md:pt-16">
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
      <h2 class="h2">
        <%= t("first-steps.section5.title") %>
      </h2>
      <div class="hidden md:block">
        <%= partial "partials/arrow-link-rounded", locals: { text: t("first-steps.section5.link"), url: "#{t(:path)}/features" } %>
      </div>
    </div>
    <p class="par-lg max-w-prose text-gray-500">
      <%= t("first-steps.section5.subtitle") %>
    </p>
    <div class="self-stretch justify-start text-black text-xl font-semibold font-['Barlow'] leading-6">
      <%= t("first-steps.section5.intro") %>
    </div>
    <%= partial "/partials/features-cards" %>
    <div class="md:hidden">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("first-steps.section5.link"), url: "#{t(:path)}/features" } %>
    </div>
  </div>
</section>

<section>
  <div class="md:pt-16 overflow-hidden">
    <div class="mt-12 w-screen space-y-4 md:space-y-6 overflow-hidden">
      <% texts = t("features.page").to_a %>
      <% if texts.length > 0 %>
        <% chunks = texts.each_slice((texts.length / 3) + 1).to_a %>
        <% chunk0 = (chunks[0] * 4) + chunks[0].take(2) %>
        <% chunk1 = (chunks[1] * 4) + chunks[1].take(2) %>
        <% chunk2 = (chunks[2] * 4) + chunks[2].take(2) %>
        <div class="flex gap-4 md:gap-6 animate-slide-x" style="--translate-x: -1380px">
          <% chunk0.each do |f| %>
            <div class="text-red-500 bg-red-100 rounded-xl par-lg p-6 flex items-baseline space-x-2 whitespace-nowrap">
              <%= icon "ri-check-line", class: "w-5 h-4" %>
              <span><%= f[1][:title] %></span>
            </div>
          <% end %>
        </div>
        <div class="flex gap-4 md:gap-6 -translate-x-[2000px] animate-slide-x" style="--translate-x: calc(-2000px + 1313px)">
          <% chunk1.each do |f| %>
            <div class="text-red-500 bg-red-100 rounded-xl par-lg p-6 flex items-baseline space-x-2 whitespace-nowrap">
              <%= icon "ri-check-line", class: "w-5 h-4" %>
              <span><%= f[1][:title] %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section>
  <div class="container space-y-6 md:pt-16">
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
      <h2 class="h2">
        <%= t("first-steps.section2.title") %>
      </h2>
      <div class="hidden md:block md:flex-row">
        <%= partial "partials/arrow-link-rounded", locals: { text: t("first-steps.section2.link"), url: "#{t(:path)}/features" } %>
      </div>
    </div>
    <p class="par-lg max-w-prose text-gray-500">
      <%= t("first-steps.section2.subtitle") %>
    </p>
  </div>
  <div class="container py-12 space-y-6">
    <%= partial "/partials/testimonial-cards" %>
    <div class="md:hidden">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("first-steps.section2.link"), url: "#{t(:path)}/features" } %>
    </div>
  </div>
</section>

<section>
  <div class="container space-y-6 md:pt-16 flex flex-col md:flex-row justify-between py-12">
    <div class="space-y-6">
      <div class="flex flex-col gap-6 border-b border-gray-300 pb-6">
        <h2 class="h2 text-black">
          <%= t("first-steps.section6.title") %>
        </h2>
        <p class="par-md max-w-prose text-black">
          <%= t("first-steps.section6.intro") %>
        </p>
        <h5 class="h5 text-black">
          <%= t("first-steps.section7.title") %>
        </h5>
        <p class="par-md max-w-prose text-black">
          <%= t("first-steps.section7.intro") %>
        </p>
          <%= partial "partials/arrow-link", locals: { text: t("first-steps.section7.link"), url: "https://docs.decidim.org/en/develop/install/", classes: "text-red-500 mt-auto block", icon_name: "ri-external-link-line" } %>
      </div>
      <div class="flex flex-col gap-6">
        <h5 class="h5 text-black">
          <%= t("first-steps.section8.title") %>
        </h5>
        <p class="par-md max-w-prose text-black">
          <%= t("first-steps.section8.intro") %>
        </p>
          <%= partial "partials/arrow-link", locals: { text: t("first-steps.section8.link"), url: "#{t(:path)}/partners", classes: "text-red-500 mt-auto block" } %>
      </div>
    </div>
    <div class="w-full md:w-2/5">
      <img src="/images/how_to_start_decidim.jpg" alt="How to start Decidim" class="w-full">
    </div>
  </div>
</section>

<section class="container py-12 md:pt-16">
  <div class="space-y-6 p-8 bg-gray-100 rounded-xl">
    <h2 class=" text-black text-5xl font-light">
      <%= t("first-steps.section4.title") %>
    </h2>
    <p class="par-lg max-w-prose text-black">
      <%= t("first-steps.section4.subtitle") %>
    </p>
    <p class="par-lg max-w-prose text-black">
      <%= t("first-steps.section4.intro") %>
    </p>
    <div class="inline-flex flex-col md:flex-row gap-4 par-md">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("first-steps.section4.button1"), url: "#{t(:path)}/about", classes: "text-black", outline_classes: "outline-black", hover_bg_classes: "hover:bg-white" } %>
    </div>
  </div>
</section>

<%= partial "/partials/cta-banner" %>
