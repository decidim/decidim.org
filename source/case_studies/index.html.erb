---
nav: case_studies
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24">
    <div class="md:w-3/5">
      <h1 class="h1 md:whitespace-nowrap">
        <%= t("case_studies.title") %>
      </h1>
      <p class="par-xl pt-5 md:pt-5">
        <%= t("case_studies.subtitle") %>
      </p>
      <div class="par-md pt-4 md:pt-5">
        <%= t("case_studies.intro") %>
      </div>
    </div>
  </div>
</section>

<div class="container pb-10">
  <div class="relative">
    <label class="sr-only" for="modules-search"><%= t("modules.placeholder") %></label>
    <input id="modules-search" class="bg-gray-50 border border-gray-300 rounded-xl w-full py-3 pl-9 pr-3 par-sm relative placeholder:text-gray-500 text-gray-500" type="text" placeholder="<%= t('modules.placeholder') %>" aria-label="<%= t('modules.placeholder') %>">
    <%= icon "ri-search-line", class: "text-gray-500 absolute top-1/2 -translate-y-1/2 left-3 w-5 h-5" %>
  </div>
</div>

<div class="container pb-16">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% sitemap.resources
        .select { |r| r.path.start_with?("case_studies/en/") && r.path.end_with?(".html") }
        .sort_by { |r| r.data.title.to_s }
        .each do |resource| %>
      <% cs = resource.data %>
      <a href="<%= resource.url %>" class="group rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow flex flex-col">
        <% if cs.image.present? %>
          <div class="aspect-video overflow-hidden bg-gray-100">
            <img src="<%= cs.image %>" alt="<%= cs.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
          </div>
        <% end %>
        <div class="p-6 flex flex-col flex-1">
          <div class="flex gap-2 flex-wrap mb-3">
            <% if cs.type.present? %>
              <span class="text-xs border border-gray-300 rounded-full px-3 py-1"><%= cs.type %></span>
            <% end %>
            <% if cs.country.present? %>
              <span class="text-xs border border-gray-300 rounded-full px-3 py-1"><%= cs.country %></span>
            <% end %>
          </div>
          <h3 class="h5 mb-2"><%= cs.title %></h3>
          <p class="par-md text-gray-600 line-clamp-3 flex-1"><%= cs.subtitle %></p>
        </div>
      </a>
    <% end %>
  </div>
</div>
