---
nav: used_by
description:
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24">
    <div class="md:w-3/5">
      <h1 class="h1 md:text-6xl md:whitespace-nowrap">
        <%= t("used_by.title") %>
      </h1>
      <p class="par-xl pt-5 md:pt-5">
        <%= t("used_by.subtitle") %>
      </p>
      <div class="par-md pt-4 md:pt-5">
        <%= t("used_by.intro") %>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container pb-24">
    <div class="flex flex-col md:pb-5 md:flex-row md:justify-between md:items-start gap-4 pt-5">
      <h2 class="h2">
        <%= t("used_by.case_studies.title") %>
      </h2>
      <div class="hidden md:block">
        <%= partial "partials/arrow-link-rounded", locals: { text: t("used_by.case_studies.link"), url: "#{t(:path)}/features" } %>
      </div>
    </div>
    <%= partial "/partials/testimonial-cards" %>
    <div class="md:hidden">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("used_by.case_studies.link"), url: "#{t(:path)}/features" } %>
    </div>
  </div>
</section>

<%= partial "/partials/facts" %>

<section>
  <div class="container py-10 md:py-16">
    <div class="flex flex-col md:pb-5 md:flex-row md:justify-between md:items-start gap-4">
      <h2 class="h2">
        <%= t("used_by.whos_using.title") %>
      </h2>
      <div class="hidden md:block">
        <%= partial "partials/arrow-link-rounded", locals: { text: t("used_by.whos_using.link"), url: "#{t(:path)}/features" } %>
      </div>
    </div>
    <p class="par-md pt-4 md:pt-5"><%= t("used_by.whos_using.subtitle") %></p>
    <div class="pt-10 md:py-10">
      <% installations = data_sort_by(data_select_home(data.installations), "priority") %>
      <div class="grid grid-cols-2 sm:grid-cols-6 md:grid-cols-6 gap-4 pb-5 items-center text-black">
        <% installations.each do |id, use| %>
          <a class="flex items-center justify-center px-3 py-1 md:px-4 md:py-3 h-20 md:h-28" href="<%= use.url %>" target="_blank" rel="noopener noreferrer">
            <img class="object-contain max-h-full max-w-full" src="<%= use.image %>" alt="<%= use.title %>" />
          </a>
        <% end %>
      </div>
    </div>
    <div class="md:hidden">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("used_by.whos_using.link"), url: "#{t(:path)}/features" } %>
    </div>
  </div>
</section>

<section>
  <img src="images/hero_cover.jpg" alt="" class="w-full h-[30rem] object-cover grayscale">
</section>

<section>
  <div class="py-16">
    <h2 class="container h2"><%= t("testimonials.title") %></h2>
    <%= partial "/partials/testimonials" %>
  </div>
</section>

<%= partial "/partials/cta-banner" %>
