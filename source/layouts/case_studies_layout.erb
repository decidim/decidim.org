<%= wrap_layout :layout do %>

  <section>
    <div class="container pt-10 md:pt-16 pb-10">
      <h1 class="h1"><%= current_page.data.title %></h1>
      <p class="par-xl"><%= current_page.data.subtitle %></p>
    </div>
  </section>

  <% if current_page.data.phases.present? && current_page.data.phases.any? %>
    <div class="container py-10 md:py-16">
      <div class="relative">
        <% current_page.data.phases.each_with_index do |phase, idx| %>
          <% is_last = idx == current_page.data.phases.length - 1 %>
          <div class="relative <%= 'md:pt-10 pt-6' if idx > 0 %>">
            <% unless is_last %>
              <div class="absolute left-4 top-[2.5rem] bottom-[-1rem] w-[1px] bg-black z-0"></div>
            <% end %>
            <div class="flex items-center gap-4 pb-3">
              <span class="rounded-full text-base border border-black bg-white flex items-center justify-center w-8 h-8 flex-shrink-0 relative z-10">
                <%= idx + 1 %>
              </span>
              <h5 class="h5 ml-3">
                <%= phase.title %>
                <% if phase.count_label.present? %>
                  <span class="font-normal text-gray-500">(<%= phase.count_label %>)</span>
                <% end %>
              </h5>
            </div>
            <% if phase.body.present? %>
              <div class="ml-4 pl-10 par-md prose max-w-none pb-4">
                <%= markdownify(phase.body) %>
              </div>
            <% end %>
            <% if phase.components.present? && phase.components.any? %>
              <div class="ml-4 pl-10 pt-2">
                <p class="font-bold par-md pb-2">Components:</p>
                <ul class="space-y-2">
                  <% phase.components.each do |component| %>
                    <li class="par-md">
                      <span class="font-semibold underline"><%= component.name %>:</span>
                      <span class="prose inline"><%= markdownify(component.description) %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
