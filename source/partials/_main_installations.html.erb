<% installations = data_sort_by(data_select_home(data.installations), "priority") %>
<div class="grid grid-cols-2 sm:grid-cols-6 md:grid-cols-5 pb-5 md:pb-0 items-center text-black space-x-4">
  <% installations.each do |id, use| %>
    <a class="items-center justify-center inline-block p-5 md:p-6" href="<%= use.url %>" target="_blank" rel="noopener noreferrer">
      <img class="object-contain w-40 h-28 md:w-56 md:h-44 md:py-4" src="<%= use.image %>" alt="<%= use.title %>" />
    </a>
  <% end %>
</div>
