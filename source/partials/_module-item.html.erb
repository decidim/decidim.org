<div class="flex flex-row items-start py-5 opacity-100 transition <%= classes ||= '' %>" data-filter-target>
  <div class="flex-1 flex flex-col space-y-4">
    <label class="par-sm uppercase font-bold"><%= item.title %></label>
    <p class="par-sm text-gray-500"><%= item.description %></p>
    <a href="<%= item.url %>" class="inline-block par-sm text-red-500"><%= t("modules.more_info") %></a>
  </div>
  <% if item.image %>
    <div class="hidden md:block md:pl-10 ml-auto">
      <img src="<%= item.image %>" alt="<%= item.title %>" class="h-40 w-40 border border-gray-300 border-1 object-cover rounded-lg">
    </div>
  <% end %>
</div>
