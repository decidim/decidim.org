<% wrap_layout :layout do %>

  <section>
    <div class="container pt-10 md:pt-16 pb-10">
      <div class="md:w-3/5">
        <h1 class="h1 md:whitespace-nowrap">
          <%= current_page.data.title %>
        </h1>
        <p class="par-xl pt-5 md:pt-5">
          <%= current_page.data.subtitle %>
        </p>
      </div>
    </div>
  </section>
  <% if current_page.data.budget.present? || current_page.data.proposals_submitted.present? || current_page.data.technically_validated.present? || current_page.data.prioritized.present? || current_page.data.selected_for_implementation.present? || current_page.data.total_participants.present? %>
    <section>
      <div class="container py-8 md:py-16">
        <p class="par-sm font-bold uppercase tracking-widest flex items-center gap-2 md:pb-6 pb-2 border-b border-gray-100">
          <%= icon "ri-numbers-line", class: "w-4 h-4" %>
          Results
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-x-4 gap-y-5 pt-5 justify-items-start">
          <% if current_page.data.budget.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.budget %></p>
              <p class="par-sm font-bold text-balance">Budget allocated</p>
            </div>
          <% end %>
          <% if current_page.data.proposals_submitted.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.proposals_submitted %></p>
              <p class="par-sm font-bold text-balance">Proposals submitted</p>
            </div>
          <% end %>
          <% if current_page.data.technically_validated.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.technically_validated %></p>
              <p class="par-sm font-bold text-balance">Technically validated</p>
            </div>
          <% end %>
          <% if current_page.data.prioritized.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.prioritized %></p>
              <p class="par-sm font-bold">Prioritised</p>
            </div>
          <% end %>
          <% if current_page.data.selected_for_implementation.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.selected_for_implementation %></p>
              <p class="par-sm font-bold text-balance">Selected for implementation</p>
            </div>
          <% end %>
          <% if current_page.data.total_participants.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-0 pb-2"><%= current_page.data.total_participants %></p>
              <p class="par-sm font-bold text-balance">Total participants</p>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
  <section>
    <% if current_page.data.phases.present? && current_page.data.phases.any? %>
      <div class="container py-10 md:py-16">
        <div class="relative">
          <% current_page.data.phases.each_with_index do |phase, idx| %>
            <% is_last = idx == current_page.data.phases.length - 1 %>
            <div class="relative <%= 'md:pt-10 pt-6' if idx > 0 %>">
              <div class="absolute left-4 top-[2.5rem] bottom-[-1rem] w-[1px] bg-black z-0"></div>
              <div class="hidden md:block">
                <div class="flex items-center gap-4 pb-3">
                  <span class="rounded-full text-base border border-black bg-white flex items-center justify-center w-8 h-8 flex-shrink-0 relative z-10">
                    <%= idx + 1 %>
                  </span>
                  <h5 class="h5 ml-3">
                    <%= phase.title %>
                    <% if phase.count_label.present? %>
                      <span class="font-normal text-gray-500">(<%= phase.count_label %>)</span>
                    <% end %>
                  </h5>
                </div>
                <div class="ml-4 pl-10 pb-6">
                  <% if phase.body.present? %>
                    <div class="par-md prose max-w-none pb-4">
                      <%= markdown(phase.body) %>
                    </div>
                  <% end %>
                  <% if phase.components.present? && phase.components.any? %>
                    <div class="pt-2">
                      <p class="font-bold par-md pb-2">Components:</p>
                      <ul class="space-y-2">
                        <% phase.components.each do |component| %>
                          <li class="par-md">
                            <span class="font-semibold underline"><%= component.name %>:</span>
                            <span class="prose inline"><%= markdown(component.description) %></span>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="block md:hidden">
                <% unless is_last %>
                  <div class="absolute left-4 top-0 bottom-0 w-[1px] bg-black z-0"></div>
                <% end %>
                <details class="group relative" <%= 'open' if idx == 0 %>>
                  <summary class="flex items-center gap-4 pb-3 cursor-pointer list-none">
                    <span class="absolute left-0 rounded-full border border-black bg-white flex items-center justify-center w-8 h-8 z-10">
                      <%= idx + 1 %>
                    </span>
                    <h5 class="h5 ml-3 flex-1 pl-6">
                      <%= phase.title %>
                      <% if phase.count_label.present? %>
                        <span class="font-normal text-gray-500">(<%= phase.count_label %>)</span>
                      <% end %>
                    </h5>
                    <span class="w-5 h-5 flex-shrink-0">
                      <span class="group-open:hidden"><%= icon "ri-arrow-down-s-line", class: "w-5 h-5 text-black block" %></span>
                      <span class="hidden group-open:block"><%= icon "ri-arrow-up-s-line", class: "w-5 h-5 text-black block" %></span>
                    </span>
                  </summary>
                  <div class="ml-4 pl-6 pb-6">
                    <% if phase.body.present? %>
                      <div class="par-md prose max-w-none pb-4">
                        <%= markdown(phase.body) %>
                      </div>
                    <% end %>
                    <% if phase.components.present? && phase.components.any? %>
                      <div class="pt-2">
                        <p class="font-bold par-md pb-2">Components:</p>
                        <ul class="space-y-2">
                          <% phase.components.each do |component| %>
                            <li class="par-md">
                              <span class="font-semibold underline"><%= component.name %>:</span>
                              <span class="prose inline"><%= markdown(component.description) %></span>
                            </li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                  </div>
                </details>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <%= yield %>
<% end %>
