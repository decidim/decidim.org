---
nav: book
description:
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24 ">
    <div class="md:w-3/5 space-y-5">
      <h1 class="h1 md:whitespace-nowrap">
        <%= t("book.title") %>
      </h1>
      <p class="par-xl text-black">
        <%= t("book.subtitle") %>
      </p>
      <div class="par-md text-black">
        <%= t("book.intro") %>
      </div>
      <%= partial "partials/arrow-link", locals: { text: t("book.cta"), url: "https://link.springer.com/book/10.1007/978-3-031-50784-7", icon_name: "ri-external-link-line", icon_classes: "w-6 h-6" } %>
    </div>
  </div>
</section>
<section>
  <div class="container md:pb-24 pb-10">
    <div class="flex flex-col md:flex-row justify-start items-stretch divide-y-2 md:divide-y-0 divide-gray-300 border-b-2 md:border-b-0 border-gray-300">
      <% data.book.each do |item| %>
        <div class="flex flex-col md:border-l pb-5 pt-10 border-gray-300 md:first:border-l-0 px-0 md:px-5 md:first:pl-0 md:py-0 w-full">
          <div class="flex items-center space-x-2">
            <%= icon item.icon, class: "w-6 h-6" %>
            <span class="font-semibold uppercase"><%= t(item.title) %></span>
          </div>
          <ul class="par-md max-w-prose text-black pt-6 list-disc list-inside space-y-2">
            <% t(item.text).each do |text| %>
              <li><%= text %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</section>
<section class="flex justify-center md:pb-24 pb-10">
  <div>
    <img src="images/ebook_decidim.svg" alt="ebook Decidim">
  </div>
</section>
