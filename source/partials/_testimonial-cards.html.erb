<div class="flex flex-col md:flex-row items-stretch gap-5">
  <% data.case_studies.sample(3)&.each do |case_study| %>
    <div class="md:w-1/3 flex flex-col pb-4 rounded-lg outline outline-1 outline-offset-[-1px] outline-gray-300">
      <div class="overflow-hidden rounded-t-lg bg-gray-300 mb-4"><img class="w-full aspect-[2/1] object-cover" src="<%= case_study.image %>" alt="<%= case_study.name %>"></div>
      <h5 class="h5 mb-4 pl-6"><%= t("case_study.#{case_study.id}.org") %></h5>
      <%= partial "partials/arrow-link", locals: { text: t("first-steps.section3.link"), url: case_study.url, classes: "text-red-500 mt-auto block pl-6" } %>
    </div>
  <% end %>
</div>
