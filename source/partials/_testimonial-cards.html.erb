<% limit = defined?(limit) ? limit : nil %>
<% sitemap.resources
    .select { |r| r.path.start_with?("case-studies/en/") && r.path.end_with?(".html") }
    .then { |resources| limit ? resources.first(limit) : resources }
    .each do |resource| %>
  <% cs = resource.data %>
  <div class="flex flex-col pb-4 rounded-lg outline outline-1 outline-offset-[-1px] outline-gray-300 flex-1"
        data-cs-card
        data-type="<%= cs.type.to_s %>"
        data-country="<%= cs.country.to_s %>">
    <div class="overflow-hidden rounded-t-lg bg-gray-300">
      <% gallery_image = cs.gallery&.first %>
        <% if gallery_image %>
            <img class="w-full h-full aspect-[2/1] object-cover" src="<%= gallery_image.image %>" alt="<%= gallery_image.alt.present? ? gallery_image.alt : cs.title %>">
          <% else %>
            <img class="w-full h-full aspect-[2/1] object-cover" src="/images/placeholder.jpg" alt="<%= cs.title %>">
        <% end %>
    </div>
    <div class="flex gap-2 flex-wrap px-6 pt-4">
      <% if cs.type.present? %>
        <span class="text-xs bg-red-100 text-red-500 rounded px-2 py-1"><%= cs.type %></span>
      <% end %>
      <% if cs.country.present? %>
        <span class="text-xs bg-red-100 text-red-500 rounded px-2 py-1"><%= cs.country %></span>
      <% end %>
    </div>
    <h5 class="h5 pt-4 px-6 line-clamp-2"><%= cs.title %></h5>
    <p class="par-md pt-4 text-gray-500 px-6 line-clamp-3"><%= cs.subtitle %></p>
    <%= partial "partials/arrow-link", locals: { text: t("case_studies.read"), url: resource.url, classes: "text-red-500 mt-auto block pl-6 pt-4" } %>
  </div>
<% end %>
