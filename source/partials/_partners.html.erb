<% limit = defined?(limit) ? limit : nil %>
<% resources = blog(:partners).articles %>
<% resources = limit ? resources.first(limit) : resources %>
<% resources.each do |resource| %>
  <% cs = resource.data %>
  <div class="flex flex-col md:p-4 p-3 rounded-lg outline outline-1 outline-offset-[-1px] outline-gray-300 flex-1"
    data-cs-card
    data-type="<%= Array(cs.type).join(" | ") %>"
    data-region="<%= cs.region.to_s %>">
    <div class="overflow-hidden rounded-t-lg bg-white">
      <% gallery_image = cs.gallery&.first %>
      <% if cs.image %>
        <img class="w-full h-28 object-contain object-center md:py-8 py-8 px-5" src="<%= cs.image %>" alt="<%= cs.alt.present? ? cs.alt : cs.title %>">
      <% else %>
        <img class="w-full h-28 object-contain object-center md:py-8 py-8 px-5" src="/images/placeholder.jpg" alt="<%= cs.title %>">
      <% end %>
    </div>
    <div class="flex gap-2 flex-wrap md:pb-16 md:h-16 overflow-hidden">
      <% Array(cs.type).each do |type| %>
        <span class="text-sm bg-red-100 text-red-500 rounded px-2 py-1"><%= type %></span>
      <% end %>
      <% if cs.region.present? %>
        <span class="text-sm bg-red-100 text-red-500 rounded px-2 py-1"><%= cs.region %></span>
      <% end %>
    </div>
    <p class="md:py-3 pb-4 pt-3 md:text-2xl text-xl font-bold text-black"><%= cs.name %></p>
    <%= partial "partials/arrow-link", locals: { text: t("partners.read"), url: resource.url, classes: "text-red-500 mt-auto block" } %>
  </div>
<% end %>
