---
nav: who_uses
description:
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24">
    <div class="md:w-3/5">
      <h1 class="h1 md:text-6xl md:whitespace-nowrap">
        <%= t("who-uses.title") %>
      </h1>
      <p class="par-xl pt-5 md:pt-5">
        <%= t("who-uses.subtitle") %>
      </p>
      <div class="par-md pt-4 md:pt-5">
        <%= t("who-uses.intro") %>
      </div>
      <p class="md:pt-5 pt-4 md:pb-0 pb-10 par-md">
        <a href="/uploads/installations.csv" class="text-red-500 inline-flex items-center gap-2">
          <span class="md:hidden"><%= t("who-uses.download_csv_short") %></span>
          <span class="hidden md:inline"><%= t("who-uses.download_csv") %></span>
          <%= icon("ri-download-line", class: "w-6 h-6 shrink-0") %>
        </a>
      </p>
    </div>
  </div>
</section>

<section>
  <div class="container md:pb-16 pb-10" data-tabs="used_by" data-filter>
    <% installations = data_sort_by(data.installations, "priority") %>
    <% region = data_select_by_type(installations, "region") %>
    <% city = data_select_by_type(installations, "city") %>
    <% org = data_select_by_type(installations, "org") %>
    <% university = data_select_by_type(installations, "university") %>
    <% filters = [installations, region, city, org, university] %>

    <div class="relative pb-4 md:pb-0">
      <input class="bg-gray-50 border border-gray-300 rounded-xl w-full py-3 pl-9 pr-3 par-sm relative placeholder:text-gray-500 text-gray-500" type="text" aria-label="<%= t('modules.placeholder') %>" placeholder="<%= t('modules.placeholder') %>">
      <%= icon "ri-search-line", class: "text-gray-500 absolute top-6 -translate-y-1/2 md:pr-1 left-3 w-5 h-5" %>
    </div>

    <ul role="tablist" aria-label="<%= t('who-uses.title') %>" class="flex items-center gap-3 md:gap-4 flex-wrap md:pt-6 mb-8 md:mb-16">
      <% filters.each_with_index do |filter, i| %>
        <li id="used-by-tab-f<%= i %>" role="tab" aria-selected="<%= i == 0 %>" aria-controls="used-by-panel-f<%= i %>" tabindex="<%= i == 0 ? 0 : -1 %>" class="flex items-center px-4 py-2 rounded-xl text-red-500 bg-red-100 hover:text-white hover:bg-red-500 transition cursor-pointer <%= 'is-selected' if i == 0 %>" data-tab-id="f<%= i %>">
          <span class="par-md whitespace-nowrap">
            <%= t("used_by.filters.f#{i}") %>
          </span>
        </li>
      <% end %>
    </ul>

    <% filters.each_with_index do |filter, i| %>
      <div id="used-by-panel-f<%= i %>" role="tabpanel" aria-labelledby="used-by-tab-f<%= i %>" class="hidden <%= 'is-selected' if i == 0 %>" data-tab-content="f<%= i %>" <%= 'hidden' if i != 0 %>>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-x-5 md:gap-y-5">
          <% filter.each do |id, use| %>
            <a class="inline-block p-5 md:p-6" href="<%= use.url %>" target="_blank" rel="noopener noreferrer" data-filter-target>
              <img loading="lazy" class="object-contain w-40 h-28 md:w-56 md:h-44" src="<%= use.image %>" alt="<%= use.title %>" />
              <span class="hidden"><%= use.title %> - <%= use.url %></span>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="par-xs text-gray-500 md:pt-10">
      <%= t("used_by.disclaimer") %>
      <p>
        <%= link_to t("used_by.download_csv"), "/uploads/installations.csv", class: "underline" %>
      </p>
    </div>
  </div>
</section>

<%= partial "/partials/cta-banner" %>
