<div class="md:grid md:grid-cols-3 grid-cols-2 gap-8">
  <% data.team.each do |member| %>
    <% if member.type == type %>
      <div class="team-member">
        <h3><%= member.name %></h3>
        <p><%= member.role %></p>
        <p><%= member.bio %></p>
      </div>
    <% end %>
  <% end %>
</div>
