<% wrap_layout :layout do %>

  <section>
    <div class="container pt-10 md:pt-16 pb-10">
      <div class="pb-10">
        <%= partial "partials/arrow-link", locals: { text: t("case_studies.use_cases_index_path"), url: "/case_studies", reverse: true, icon_classes: "w-5 h-5" } %>
      </div>
      <div class="md:w-3/5">
        <h1 class="h1 md:nowrap ">
          <%= current_page.data.title %>
        </h1>
        <p class="par-xl pt-5 md:pt-5">
          <%= current_page.data.subtitle %>
        </p>
          <%= partial "partials/arrow-link", locals: { url: current_page.data.website, text: current_page.data.website_link_text.present? ? current_page.data.website_link_text : current_page.data.website, classes: "text-red-500 mt-auto block pt-5 ", span_classes: "par-sm", icon_classes: "w-5 h-5", icon_name: "ri-external-link-line" } %>
      </div>
    </div>
  </section>

  <section>
    <% if current_page.data.gallery.present? && current_page.data.gallery.any? %>
    <div class="container md:pr-80">
      <div class="flex flex-col md:flex-row gap-2 md:h-[500px]">

        <div class="w-full md:flex-1 overflow-hidden rounded-lg h-[300px] md:h-full" id="main-gallery-image">
          <img class="w-full h-full object-cover" src="<%= current_page.data.gallery.first.image %>" alt="<%= current_page.data.gallery.first.alt %>">
        </div>

        <% if current_page.data.gallery.length > 1 %>
        <div class="flex md:flex-col flex-row gap-2 md:w-36 md:pl-3 overflow-x-auto md:overflow-x-visible overflow-y-visible md:overflow-y-visible">
          <% current_page.data.gallery.each_with_index do |photo, i| %>
          <div class="flex-shrink-0 md:flex-1 w-28 h-20 md:w-auto md:h-auto overflow-hidden rounded-lg relative cursor-pointer gallery-thumb"
            onclick="selectGalleryImage(this)" data-src="<%= photo.image %>" data-alt="<%= photo.alt %>">
            <img class="w-full h-full object-cover" src="<%= photo.image %>" alt="<%= photo.alt %>">
            <div class="absolute inset-0 bg-gray-100/40 rounded-lg transition-opacity duration-200 thumb-overlay <%= i == 0 ? 'opacity-0' : 'opacity-100' %>"></div>
          </div>
          <% end %>
        </div>
        <% end %>
      </div>
    </div>
    <% end %>
  </section>

  <section>
    <div class="container pt-8 md:pt-16 md:pr-80">
      <% if current_page.data.type.present? %>
        <div class="pb-4 mb-4">
          <p class="par-sm font-bold uppercase flex items-center gap-2 py-3 border-b border-gray-300">
            <%= icon "ri-service-line", class: "w-4 h-4" %>
            <%= t("case_studies.type_of_process") %>
          </p>
          <p class="par-md"><%= current_page.data.type %></p>
        </div>
      <% end %>
      <% if current_page.data.target.present? %>
        <div class="pb-4">
          <p class="par-sm font-bold uppercase flex items-center gap-2 py-3 border-b border-gray-300">
            <%= icon "ri-user-line", class: "w-4 h-4" %>
            <%= t("case_studies.target_public") %>
          </p>
          <p class="par-md"><%= current_page.data.target %></p>
        </div>
      <% end %>
      <% if current_page.data.components_used.present? && current_page.data.components_used.any? %>
        <div class="pb-4 mb-4">
          <p class="par-sm font-bold uppercase flex items-center gap-2 py-3 border-b border-gray-300">
            <%= icon "ri-apps-2-line", class: "w-4 h-4" %>
            <%= t("case_studies.components_used") %>
          </p>
          <ul class="list-disc list-inside space-y-1">
            <% current_page.data.components_used.each do |component| %>
              <li class="par-md"><%= component %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </section>
  <section>
    <% if current_page.data.budget&.value.present? || current_page.data.proposals_submitted&.value.present? || current_page.data.technically_validated&.value.present? || current_page.data.prioritized&.value.present? || current_page.data.selected_for_implementation&.value.present? || current_page.data.total_participants&.value.present? %>
      <div class="container md:pt-8 md:pr-80">
        <p class="par-sm font-bold uppercase flex items-center gap-2 md:pb-3 pb-2 border-b border-gray-300">
          <%= icon "ri-numbers-line", class: "w-4 h-4" %>
          <%= current_page.data.results_title.present? ? current_page.data.results_title : "Results" %>
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 justify-items-start">
          <% if current_page.data.budget&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 py-2 md:pt-5"><%= current_page.data.budget.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.budget.label.present? ? current_page.data.budget.label : "Budget allocated" %></p>
            </div>
          <% end %>
          <% if current_page.data.proposals_submitted&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 py-2 md:pt-5"><%= current_page.data.proposals_submitted.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.proposals_submitted.label.present? ? current_page.data.proposals_submitted.label : "Proposals submitted" %></p>
            </div>
          <% end %>
          <% if current_page.data.technically_validated&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.technically_validated.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.technically_validated.label.present? ? current_page.data.technically_validated.label : "Technically validated" %></p>
            </div>
          <% end %>
          <% if current_page.data.prioritized&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.prioritized.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.prioritized.label.present? ? current_page.data.prioritized.label : "Prioritized" %></p>
            </div>
          <% end %>
          <% if current_page.data.selected_for_implementation&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.selected_for_implementation.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.selected_for_implementation.label.present? ? current_page.data.selected_for_implementation.label : "Selected for implementation" %></p>
            </div>
          <% end %>
          <% if current_page.data.total_participants&.value.present? %>
            <div class="flex flex-col justify-start md:w-96 md:h-36 w-full">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.total_participants.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.total_participants.label.present? ? current_page.data.total_participants.label : "Total participants" %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="container md:pt-5 md:pb-16 pt-5">
      <% if current_page.data.results_conclusion.present? %>
        <div class="prose par-md max-w-none text-gray-500">
          <%= markdown(current_page.data.results_conclusion) %>
        </div>
      <% end %>
    </div>
  </section>
  <section>
    <% if current_page.data.description.present? %>
      <div class="container md:pb-16 md:pr-80">
        <div class="prose par-md max-w-none text-black">
          <%= markdown(current_page.data.description) %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <div class="container md:pr-80">
      <h2 class="h2 md:nowrap ">
        <%= current_page.data.process_title %>
      </h2>
      <p class="par-lg pt-5 md:pt-5">
        <%= current_page.data.process_subtitle %>
      </p>
    </div>
    <% if current_page.data.phases.present? && current_page.data.phases.any? %>
      <div class="container py-10 md:pt-16 md:pr-80">
        <div class="relative">
          <% current_page.data.phases.each_with_index do |phase, idx| %>
            <% is_last = idx == current_page.data.phases.length - 1 %>
            <div class="relative <%= 'md:pt-10 pt-6' if idx > 0 %>">
              <div class="absolute left-4 top-[2.5rem] bottom-[-1rem] w-[1px] bg-black z-0"></div>
              <div class="hidden md:block">
                <div class="flex items-center gap-4 pb-3">
                  <span class="rounded-full text-base border border-black bg-white flex items-center justify-center w-8 h-8 flex-shrink-0 relative z-10">
                    <%= idx + 1 %>
                  </span>
                  <h5 class="h5 ml-3">
                    <%= phase.title %>
                    <% if phase.count_label.present? %>
                      <span class="font-normal text-black">(<%= phase.count_label %>)</span>
                    <% end %>
                  </h5>
                </div>
                <div class="ml-4 pl-10 pb-6">
                  <% if phase.body.present? %>
                    <div class="par-md prose max-w-none pb-4 text-black">
                      <%= markdown(phase.body) %>
                    </div>
                  <% end %>
                  <% if phase.components.present? && phase.components.any? %>
                    <div class="pt-2">
                      <p class="font-bold par-md pb-2"><%= t("case_studies.components") %></p>
                      <ul class="space-y-2">
                        <% phase.components.each do |component| %>
                          <li class="par-md prose inline text-black">
                            <%= markdown(component.description) %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>
                </div>
              </div>
              <div class="block md:hidden">
                <% unless is_last %>
                  <div class="absolute left-4 top-0 bottom-0 w-[1px] bg-black z-0"></div>
                <% end %>
                <details class="group relative" <%= 'open' if idx == 0 %>>
                  <summary class="flex items-center gap-4 pb-3 cursor-pointer list-none">
                    <span class="absolute left-0 rounded-full border border-black bg-white flex items-center justify-center w-8 h-8 z-10">
                      <%= idx + 1 %>
                    </span>
                    <h5 class="h5 ml-3 flex-1 pl-6">
                      <%= phase.title %>
                      <% if phase.count_label.present? %>
                        <span class="font-normal text-black">(<%= phase.count_label %>)</span>
                      <% end %>
                    </h5>
                    <span class="w-5 h-5 flex-shrink-0">
                      <span class="group-open:hidden"><%= icon "ri-arrow-down-s-line", class: "w-5 h-5 text-black block" %></span>
                      <span class="hidden group-open:block"><%= icon "ri-arrow-up-s-line", class: "w-5 h-5 text-black block" %></span>
                    </span>
                  </summary>
                  <div class="ml-4 pl-6 pb-6">
                    <% if phase.body.present? %>
                      <div class="par-md prose max-w-none pb-4 text-black">
                        <%= markdown(phase.body) %>
                      </div>
                    <% end %>
                    <% if phase.components.present? && phase.components.any? %>
                      <div class="pt-2">
                        <p class="font-bold par-md pb-2"><%= t("case_studies.components") %></p>
                        <ul class="space-y-2">
                          <% phase.components.each do |component| %>
                            <li class="par-md prose inline text-black">
                              <%= markdown(component.description) %>
                            </li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                  </div>
                </details>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <% if current_page.data.phases_conclusion.present? %>
      <div class="container md:pb-10 pb-5 md:pr-80">
        <div class="prose par-md max-w-none text-black">
          <%= markdown(current_page.data.phases_conclusion) %>
        </div>
      </div>
    <% end %>
  </section>
  <section class="bg-red-100">
    <% if current_page.data.banner.present? && current_page.data.banner_title.present? && current_page.data.banner_subtitle.present? %>
      <div class="container py-8 md:py-16 md:pr-80">
        <h2 class="text-5xl text-red-500 md:nowrap">
          <%= markdown(current_page.data.banner_title) %>
        </h2>
        <div class="text-4xl font-bold text-red-500 md:pb-6 pb-5">
          <%= markdown(current_page.data.banner_subtitle) %>
        </div>
        <div class="par-md text-red-500 prose max-w-none pb-4">
          <%= markdown(current_page.data.banner) %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <% if current_page.data.optional_section_1.present? || current_page.data.optional_section_2.present? || current_page.data.optional_section_3.present? %>
      <div class="container pt-8 md:pr-80">
        <% if current_page.data.optional_section_1.present? %>
          <div class="prose par-md max-w-none text-black py-10">
            <%= markdown(current_page.data.optional_section_1) %>
          </div>
        <% end %>
        <% if current_page.data.optional_section_2.present? %>
          <div class="prose par-md max-w-none text-black pb-10">
            <%= markdown(current_page.data.optional_section_2) %>
          </div>
        <% end %>
        <% if current_page.data.optional_section_3.present? %>
          <div class="prose par-md max-w-none text-black pb-10">
            <%= markdown(current_page.data.optional_section_3) %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
  <section>
    <% if current_page.data.testimonial_link.present? %>
      <div class="container py-8 md:py-10 md:pr-80">
        <h2 class="h2 md:nowrap pb-6">
          <%= t("case_studies.testimonial") %>
        </h2>
        <%= partial "partials/arrow-link", locals: { url: current_page.data.testimonial_link, text: current_page.data.testimonial_link_text.present? ? current_page.data.testimonial_link_text : current_page.data.testimonial_link, classes: "text-red-500 block pt-4 underline", span_classes: "par-md", icon_classes: "w-6 h-6", icon_name: "ri-external-link-line" } %>
      </div>
    <% end %>
  </section>
  <section class="md:pb-10">
    <% if current_page.data.partners.present? && current_page.data.partners.any? %>
      <div class="container md:pr-80">
        <h2 class="h2 md:nowrap pb-6">
          <%= t("case_studies.partners") %>
        </h2>
        <div class="flex flex-wrap gap-6 md:gap-8 items-center">
          <% current_page.data.partners.each do |partner| %>
            <div class="flex items-center pb-5">
              <img src="<%= partner.logo %>" alt="<%= partner.name %>" class="h-10 md:h-16 object-contain">
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <% if current_page.data.collaboration_text.present? %>
      <div class="container pb-8 md:pb-16 md:pr-80">
        <div class="prose par-md max-w-none text-gray-500">
          <%= markdown(current_page.data.collaboration_text) %>
        </div>
      </div>
    <% end %>
  </section>
  <%= yield %>
<% end %>
