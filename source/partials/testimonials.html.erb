<% testimonials = data.testimonials.sample(3) %>
<section>
  <div class="container pt-8 pb-12 md:py-24" data-tabs="testimonials">
    <div class="hidden md:grid grid-cols-3 gap-6 items-start">
      <% testimonials&.each_with_index do |f, i| %>
        <div class="flex flex-col space-y-4">
          <div class="flex items-center space-x-4">
            <img class="w-12 h-12 rounded-t-xl rounded-br-xl object-cover flex-shrink-0" src="<%= f.image %>" alt="<%= f.name %>">
            <cite class="not-italic">
              <span class="block font-bold"><%= f.name %></span>
              <span class="block text-gray-500 text-sm"><%= t("testimonials.#{f.id}.org") %></span>
            </cite>
          </div>
          <blockquote class="par-md bg-red-100 rounded-tr-xl rounded-b-xl p-6 text-red-500">
            <%= t("testimonials.#{f.id}.quote") %>
          </blockquote>
        </div>
      <% end %>
    </div>
    <div class="md:hidden">
      <% testimonials&.each_with_index do |f, i| %>
        <div class="hidden flex-col space-y-4 <%= 'is-selected' if i == 0 %>" data-tab-content="<%= i %>">
          <div class="flex items-center space-x-4">
            <img class="w-12 h-12 rounded-t-xl rounded-br-xl object-cover flex-shrink-0" src="<%= f.image %>" alt="<%= f.name %>">
            <cite class="not-italic">
              <span class="block font-bold"><%= f.name %></span>
              <span class="block text-gray-500 text-sm"><%= t("testimonials.#{f.id}.org") %></span>
            </cite>
          </div>
          <blockquote class="par-md bg-red-100 rounded-tr-xl rounded-b-xl p-6 text-red-500">
            <%= t("testimonials.#{f.id}.quote") %>
          </blockquote>
        </div>
      <% end %>
      <ul role="tablist" class="flex space-x-3 mt-8">
        <% testimonials&.each_with_index do |feat, i| %>
          <li role="tab" tabindex="0" class="h-2 w-10 bg-gray-300 rounded-xl cursor-pointer <%= 'is-selected' if i == 0 %>" data-tab-id="<%= i %>" data-tab-mobile></li>
        <% end %>
      </ul>
    </div>
  </div>
</section>
