<div class="md:grid md:grid-cols-3 grid-cols-2 gap-8">
  <% data.association.each do |member| %>
    <% if member.type == type %>
      <div class="team-card [perspective:1000px] cursor-pointer hover:shadow-lg transition-shadow duration-300" onclick="this.querySelector('.flip-inner').classList.toggle('rotate-y-180')">
        <div class="flip-inner relative rounded-lg w-full h-full transition-transform duration-500 [transform-style:preserve-3d]">
          <div class="absolute inset-0 flex flex-col gap-1 [backface-visibility:hidden]">
            <img src="<%= member.photo %>" alt="<%= member.name %>" class="w-96 h-96 object-cover" />
            <div class="p-4">
              <h6 class="font-semibold h6"><%= member.name %></h6>
              <p class="par-md"><%= t("team.members.#{member['key']}.role") %></p>
            </div>
          </div>
          <div class="flip-back absolute inset-0 flex flex-col gap-3 p-4 bg-red-100 rounded shadow [backface-visibility:hidden] [transform:rotateY(180deg)]">
            <p class="par-sm"><%= t("team.members.#{member['key']}.bio") %></p>
            <% if member.linkedin_url && !member.linkedin_url.to_s.empty? %>
              <a href="<%= member.linkedin_url %>" target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-1 text-md text-red-500 hover:underline" onclick="event.stopPropagation()">
                <%= icon "ri-linkedin-box-fill", class: "w-5 h-5" rescue nil %>
                /LinkedIn
              </a>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
