<% wrap_layout :layout do %>

  <section>
    <div class="container pt-10 md:pt-16 pb-10">
      <div class="md:w-3/5">
        <h1 class="h1 md:nowrap ">
          <%= current_page.data.title %>
        </h1>
        <p class="par-xl pt-5 md:pt-5">
          <%= current_page.data.subtitle %>
        </p>
          <%= partial "partials/arrow-link", locals: { url: current_page.data.website, text: current_page.data.website, classes: "text-red-500 mt-auto block pt-5 ", span_classes: "text-[20px] leading-[28px]", icon_classes: "w-6 h-6", icon_name: "ri-external-link-line" } %>
      </div>
    </div>
  </section>

  <section>
    <% if current_page.data.gallery.present? && current_page.data.gallery.any? %>
      <div class="container">
        <div class="flex gap-2 h-[500px]">
          <div class="flex-1 overflow-hidden rounded-lg">
            <img class="w-full h-full object-cover" src="<%= current_page.data.gallery.first.image %>" alt="<%= current_page.data.gallery.first.alt %>">
          </div>
          <% if current_page.data.gallery.length > 1 %>
            <div class="flex flex-col gap-2 w-36 md:pl-3">
              <% current_page.data.gallery.drop(1).each do |photo| %>
                <div class="flex-1 overflow-hidden rounded-lg">
                  <img class="w-full h-full object-cover" src="<%= photo.image %>" alt="<%= photo.alt %>">
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <div class="container py-8 md:pt-16">
      <% if current_page.data.type.present? %>
        <div class="pb-4 mb-4">
          <p class="par-sm font-bold uppercase tracking-widest flex items-center gap-2 py-3 border-b border-gray-100">
            <%= icon "ri-service-line", class: "w-4 h-4" %>
            <%= t("case_studies.type_of_process") %>
          </p>
          <p class="par-md"><%= current_page.data.type %></p>
        </div>
      <% end %>
      <% if current_page.data.target.present? %>
        <div class="pb-4">
          <p class="par-sm font-bold uppercase tracking-widest flex items-center gap-2 py-3 border-b border-gray-100">
            <%= icon "ri-user-line", class: "w-4 h-4" %>
            <%= t("case_studies.target_public") %>
          </p>
          <p class="par-md"><%= current_page.data.target %></p>
        </div>
      <% end %>
      <% if current_page.data.components_used.present? && current_page.data.components_used.any? %>
        <div class="pb-4 mb-4">
          <p class="par-sm font-bold uppercase tracking-widest flex items-center gap-2 py-3 border-b border-gray-100">
            <%= icon "ri-apps-2-line", class: "w-4 h-4" %>
            <%= t("case_studies.components_used") %>
          </p>
          <ul class="list-disc list-inside space-y-1">
            <% current_page.data.components_used.each do |component| %>
              <li class="par-md"><%= component %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </section>
  <section>
    <% if current_page.data.budget&.value.present? || current_page.data.proposals_submitted&.value.present? || current_page.data.technically_validated&.value.present? || current_page.data.prioritized&.value.present? || current_page.data.selected_for_implementation&.value.present? || current_page.data.total_participants&.value.present? %>
      <div class="container py-8 md:pb-16">
        <p class="par-sm font-bold uppercase tracking-widest flex items-center gap-2 md:pb-3 pb-2 border-b border-gray-100">
          <%= icon "ri-numbers-line", class: "w-4 h-4" %>
          <%= current_page.data.results_title.present? ? current_page.data.results_title : "Results" %>
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 justify-items-start">
          <% if current_page.data.budget&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.budget.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.budget.label.present? ? current_page.data.budget.label : "Budget allocated" %></p>
            </div>
          <% end %>
          <% if current_page.data.proposals_submitted&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.proposals_submitted.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.proposals_submitted.label.present? ? current_page.data.proposals_submitted.label : "Proposals submitted" %></p>
            </div>
          <% end %>
          <% if current_page.data.technically_validated&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.technically_validated.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.technically_validated.label.present? ? current_page.data.technically_validated.label : "Technically validated" %></p>
            </div>
          <% end %>
          <% if current_page.data.prioritized&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.prioritized.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.prioritized.label.present? ? current_page.data.prioritized.label : "Prioritized" %></p>
            </div>
          <% end %>
          <% if current_page.data.selected_for_implementation&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.selected_for_implementation.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.selected_for_implementation.label.present? ? current_page.data.selected_for_implementation.label : "Selected for implementation" %></p>
            </div>
          <% end %>
          <% if current_page.data.total_participants&.value.present? %>
            <div class="flex flex-col justify-center md:w-96 md:h-36 w-40 h-16">
              <p class="h2 font-bold md:pb-4 pb-2"><%= current_page.data.total_participants.value %></p>
              <p class="par-md font-bold text-balance"><%= current_page.data.total_participants.label.present? ? current_page.data.total_participants.label : "Total participants" %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <% if current_page.data.description.present? %>
      <div class="container md:pb-16">
        <div class="prose par-lg max-w-none text-black">
          <%= markdown(current_page.data.description) %>
        </div>
      </div>
    <% end %>
  </section>
  <section>
    <div class="container">
      <h2 class="h2 md:nowrap ">
        <%= current_page.data.process_title %>
      </h2>
      <p class="par-lg pt-5 md:pt-5">
        <%= current_page.data.process_subtitle %>
      </p>
    </div>
    <% if current_page.data.phases.present? && current_page.data.phases.any? %>
      <div class="container py-10 md:py-16">
        <div class="relative">
          <% current_page.data.phases.each_with_index do |phase, idx| %>
            <% is_last = idx == current_page.data.phases.length - 1 %>
            <div class="relative <%= 'md:pt-10 pt-6' if idx > 0 %>">
              <div class="absolute left-4 top-[2.5rem] bottom-[-1rem] w-[1px] bg-black z-0"></div>
              <div class="hidden md:block">
                <div class="flex items-center gap-4 pb-3">
                  <span class="rounded-full text-base border border-black bg-white flex items-center justify-center w-8 h-8 flex-shrink-0 relative z-10">
                    <%= idx + 1 %>
                  </span>
                  <h5 class="h5 ml-3">
                    <%= phase.title %>
                    <% if phase.count_label.present? %>
                      <span class="font-normal text-gray-500">(<%= phase.count_label %>)</span>
                    <% end %>
                  </h5>
                </div>
                <div class="ml-4 pl-10 pb-6">
                  <% if phase.body.present? %>
                    <div class="par-md prose max-w-none pb-4">
                      <%= markdown(phase.body) %>
                    </div>
                  <% end %>
                  <% if phase.components.present? && phase.components.any? %>
                    <div class="pt-2">
                      <p class="font-bold par-md pb-2">Components:</p>
                      <ul class="space-y-2">
                        <% phase.components.each do |component| %>
                          <li class="par-md">
                            <span class="font-semibold underline"><%= component.name %>:</span>
                            <span class="prose inline"><%= markdown(component.description) %></span>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="block md:hidden">
                <% unless is_last %>
                  <div class="absolute left-4 top-0 bottom-0 w-[1px] bg-black z-0"></div>
                <% end %>
                <details class="group relative" <%= 'open' if idx == 0 %>>
                  <summary class="flex items-center gap-4 pb-3 cursor-pointer list-none">
                    <span class="absolute left-0 rounded-full border border-black bg-white flex items-center justify-center w-8 h-8 z-10">
                      <%= idx + 1 %>
                    </span>
                    <h5 class="h5 ml-3 flex-1 pl-6">
                      <%= phase.title %>
                      <% if phase.count_label.present? %>
                        <span class="font-normal text-gray-500">(<%= phase.count_label %>)</span>
                      <% end %>
                    </h5>
                    <span class="w-5 h-5 flex-shrink-0">
                      <span class="group-open:hidden"><%= icon "ri-arrow-down-s-line", class: "w-5 h-5 text-black block" %></span>
                      <span class="hidden group-open:block"><%= icon "ri-arrow-up-s-line", class: "w-5 h-5 text-black block" %></span>
                    </span>
                  </summary>
                  <div class="ml-4 pl-6 pb-6">
                    <% if phase.body.present? %>
                      <div class="par-md prose max-w-none pb-4">
                        <%= markdown(phase.body) %>
                      </div>
                    <% end %>
                    <% if phase.components.present? && phase.components.any? %>
                      <div class="pt-2">
                        <p class="font-bold par-md pb-2">Components:</p>
                        <ul class="space-y-2">
                          <% phase.components.each do |component| %>
                            <li class="par-md">
                              <span class="font-semibold underline"><%= component.name %>:</span>
                              <span class="prose inline"><%= markdown(component.description) %></span>
                            </li>
                          <% end %>
                        </ul>
                      </div>
                    <% end %>
                  </div>
                </details>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
  <section class="bg-gray-100">
    <% if current_page.data.banner.present? || current_page.data.banner_title.present? %>
      <div class="container py-8 md:py-16">
        <h2 class="text-5xl md:nowrap ">
          <%= markdown(current_page.data.banner_title) %>
        </h2>
        <div class="par-md prose max-w-none pb-4">
          <%= markdown(current_page.data.banner) %>
        </div>
      </div>
    <% end %>
  </section>

  <%= yield %>
<% end %>
