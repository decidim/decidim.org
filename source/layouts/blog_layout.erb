<% wrap_layout :layout do %>
  <div class="container pt-6 pb-6 md:pt-24">
    <div class="md:pb-10 pb-5">
      <%= partial "partials/arrow-link", locals: { text: t("blog.blog_index_path"), url: "/blog", reverse: true, icon_classes: "w-5 h-5" } %>
    </div>
    <div class="md:w-3/5">
      <h2 class="h2 pb-10 md:nowrap"><%= current_article.title %></h2>
      <div class="par-md flex md:pb-10 pb-5">
        <time><%= current_article.date.strftime('%d/%m/%Y') %></time>
      </div>
    </div>
    <% if current_page.data.gallery.present? && current_page.data.gallery.any? %>
      <div class="max-w-3xl md:pb-10 pb-5">
        <div class="flex flex-col md:flex-row gap-2 md:h-[500px]">
          <div class="w-full md:flex-1 overflow-hidden rounded-lg h-[300px] md:h-full" id="main-gallery-image" data-gallery="main">
            <img class="w-full h-full object-cover" src="<%= current_page.data.gallery.first.image %>" alt="<%= current_page.data.gallery.first.alt %>">
          </div>
          <% if current_page.data.gallery.length > 1 %>
          <div class="flex md:flex-col flex-row gap-2 md:w-36 md:pl-3 overflow-x-auto md:overflow-x-visible overflow-y-visible md:overflow-y-visible">
            <% current_page.data.gallery.each_with_index do |photo, i| %>
            <div class="flex-shrink-0 md:flex-1 w-28 h-20 md:w-auto md:h-auto overflow-hidden rounded-lg relative cursor-pointer gallery-thumb"
              onclick="selectGalleryImage(this)" data-src="<%= photo.image %>" data-alt="<%= photo.alt %>" data-gallery-thumb>
              <img class="w-full h-full object-cover" src="<%= photo.image %>" alt="<%= photo.alt %>">
            <div class="absolute inset-0 bg-gray-100/40 rounded-lg transition-opacity duration-200 thumb-overlay <%= i == 0 ? 'opacity-0' : 'opacity-100' %>" data-overlay></div>
            </div>
            <% end %>
          </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <article class="prose prose-xl text-black">
      <%= yield %>
    </article>
    <%= partial "partials/arrow-link", locals: { url: current_page.data.website, text: current_page.data.website_link_text.present? ? current_page.data.website_link_text : current_page.data.website, classes: "text-red-500 mt-auto block pt-5 md:pb-16 pb-10", span_classes: "par-sm", icon_classes: "w-5 h-5", icon_name: "ri-external-link-line" } %>
  </div>
<% end %>
