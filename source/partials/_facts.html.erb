<section class="bg-red-100">
  <div class="container pt-8 md:py-16 text-red-500">
    <h2 class="h2 md:pb-5"><%= t("used_by.facts.title") %></h2>
    <p class="par-md max-w-prose"><%= t("used_by.facts.subtitle") %></p>
    <div class="py-8 md:py-0 md:mt-16">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-8 md:gap-y-16">
        <% data.facts.each_with_index do |use, ix| %>
          <div class="space-y-1 md:space-y-3" style="--translate-ix: <%= ix %>;">
            <h2 class="text-6xl font-bold"><%= get_statistic_for_fact(use.text, use.value, data) %></h2>
            <h6 class="h6"><%= t("used_by.facts.type.#{use.text}") %></h6>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
