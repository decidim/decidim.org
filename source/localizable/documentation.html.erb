---
title: Documentation
description:
---

<section>
  <div class="container pt-10 md:pt-16">
    <div class="md:w-3/5">
      <h1 class="h1 md:text-6xl md:whitespace-nowrap">
        <%= t("documentation.title") %>
      </h1>
      <p class="par-xl pt-5 md:pt-5">
        <%= t("documentation.subtitle") %>
      </p>
      <div class="par-md pt-4 md:pt-5">
        <%= t("documentation.intro") %>
      </div>
    </div>
    <%= partial "partials/arrow-link", locals: { text: t("documentation.title"), url: "https://docs.decidim.org/en", classes: "text-red-500 par-md mt-auto block pt-5", span_classes: "text-[20px] leading-[28px]", icon_name: "ri-external-link-line", icon_classes: "w-6 h-6" } %>
  </div>
</section>

<section>
  <div class="container flex flex-col md:flex-row justify-start items-stretch divide-y-2 md:divide-y-0 divide-gray-300 border-b-2 md:border-b-0 border-gray-300 md:py-24 py-10">
    <% data.documentation.each do |item| %>
      <div class="flex flex-col md:border-l py-5 border-gray-300 md:first:border-l-0 px-0 md:px-5 md:first:pl-0 md:py-0 w-full">
        <div>
          <div class="flex items-center space-x-2">
            <%= icon item.icon, class: "w-6 h-6" %>
            <span class="font-semibold uppercase"><%= t("first-steps.#{item.pre}") %></span>
          </div>
          <h5 class="h5 pt-6"><%= t("first-steps.#{item.title}") %></h5>
          <p class="par-md max-w-prose text-black pt-3 md:pb-6"><%= t("first-steps.#{item.content}") %></p>
        </div>
        <%= partial "partials/arrow-link", locals: { text: t("first-steps.#{item.link}"), url: item.url, classes: "text-red-500 par-md block", span_classes: "text-[16px]", icon_name: "ri-external-link-line", icon_classes: "w-5 h-5" } %>
      </div>
    <% end %>
  </div>
</section>
