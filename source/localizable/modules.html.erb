---
nav: modules
description:
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24">
    <div class="md:w-3/5">
      <h1 class="h1 md:text-6xl md:whitespace-nowrap">
        <%= t("modules.title") %>
      </h1>
      <p class="par-xl text-black par-xl pt-5 md:pt-5">
        <%= t("modules.subtitle") %>
      </p>
      <div class="par-md pt-4 md:pt-5">
        <%= t("modules.intro") %>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container py-6 flex flex-col md:flex-row items-start gap-6" data-filter>
    <div class="w-full md:w-1/4 md:sticky top-0">
      <div class="flex md:flex-col gap-3 md:gap-2 mb-8">
        <div class="relative mb-2">
          <input class="bg-gray-50 border border-gray-300 rounded-xl w-full py-3 pl-9 pr-6 par-md relative placeholder:text-gray-500 text-gray-500" type="text" placeholder="<%= t('modules.placeholder') %>">
          <%= icon "ri-search-line", class: "text-gray-500 absolute top-1/2 -translate-y-1/2 left-3 w-4 h-4" %>
        </div>
        <a class="block w-full px-4 py-3 rounded-lg text-sm font-bold uppercase text-red-500 bg-red-50 hover:bg-red-100 transition" href="#official"><%= t("modules.official") %></a>
        <a class="block w-full px-4 py-3 rounded-lg text-sm font-bold uppercase text-red-500 bg-red-50 hover:bg-red-100 transition" href="#community"><%= t("modules.community") %></a>
        <a class="block w-full px-4 py-3 rounded-lg text-sm font-bold uppercase text-red-500 bg-red-50 hover:bg-red-100 transition" href="#auth"><%= t("modules.auth") %></a>
      </div>

    </div>
    <div class="md:w-3/4">
      <% modules = data_sort_by(data.modules, "title") %>
      <% official = data_select_by_type(modules, "official") %>
      <% community = data_select_by_type(modules, "community") %>
      <% auth = data_select_by_type(modules, "auth") %>

      <h4 id="official" class="h4 mb-6 md:mb-10"><%= t("modules.official") %></h4>
      <div class="divide-y-4 border-y-4 border-gray-100 divide-gray-100 overflow-hidden">
        <% official.each do |id, m| %>
          <%= partial "/partials/module-item", locals: { item: m } %>
        <% end %>
      </div>

      <div class="hidden md:block py-20">
        <p class="par-xl max-w-prose text-gray-500 mb-8"><%= t("modules.develop") %></p>
        <%= partial "/partials/cta-bare", locals: { classes: "text-red-500", text: t("modules.cta"), url: "https://docs.decidim.org" } %>
      </div>

      <h4 id="community" class="h4 mb-6 md:mb-10"><%= t("modules.community") %></h4>
      <div class="divide-y-4 border-y-4 border-gray-100 divide-gray-100 overflow-hidden">
        <% community.each do |id, m| %>
          <%= partial "/partials/module-item", locals: { item: m } %>
        <% end %>
      </div>

      <h4 id="auth" class="h4 mt-20 mb-6 md:mb-10"><%= t("modules.auth") %></h4>
      <div class="divide-y-4 border-y-4 border-gray-100 divide-gray-100 overflow-hidden">
        <% auth.each do |id, m| %>
          <%= partial "/partials/module-item", locals: { item: m } %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%= partial "/partials/faq" %>

<%= partial "/partials/cta-banner" %>
