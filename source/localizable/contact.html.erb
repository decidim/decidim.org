---
nav: contact
description:
---

<section>
  <div class="container pt-10 md:pt-16 md:pb-24">
    <div class="md:w-3/5">
      <h1 class="h1 md:text-6xl md:whitespace-nowrap">
        <%= t("contact.title") %>
      </h1>
      <p class="par-xl text-black pt-5">
        <%= t("contact.subtitle") %>&nbsp;<a class="text-red-500" href="mailto:hola@decidim.org">hola@decidim.org</a>
      </p>
    </div>
  </div>
</section>

<section>
  <div class="container py-10 md:pt-0 md:pb-16">
    <form class="flex flex-col space-y-6 md:w-3/4" method="post" action="/redirect/?page=/thanks" name="contact-en" netlify-honeypot="bot-field" data-netlify="true">
      <p class="hidden" hidden>
        <label><%= t('contact.bot_field') %> <input name="bot-field" /></label>
      </p>
      <label for="name" class="form-input">
        <input id="name" name="name" type="text" required>
        <span>
          <%= t("contact.name") %>
        </span>
      </label>
      <label for="email" class="form-input">
        <span>
          <%= t("contact.email") %>
        </span>
        <input id="email" name="email" type="email" required>
      </label>
      <div class="form-input">
        <span><%= t("contact.reason") %></span>
        <div class="absolute right-5 md:right-4 top-[2.8rem] pointer-events-none">
          <%= icon "ri-arrow-down-s-line", class: "w-5 h-5 text-black" %>
        </div>
        <select id="reason" name="reason" required>
          <option value="" selected disabled><%= t("contact.reasons.selected") %></option>
          <option value="<%= t("contact.reasons.installing") %>"><%= t("contact.reasons.installing") %></option>
          <option value="<%= t("contact.reasons.service_provider") %>"><%= t("contact.reasons.service_provider") %></option>
          <option value="<%= t("contact.reasons.community") %>"><%= t("contact.reasons.community") %></option>
          <option value="<%= t("contact.reasons.researcher") %>"><%= t("contact.reasons.researcher") %></option>
          <option value="<%= t("contact.reasons.other") %>"><%= t("contact.reasons.other") %></option>
        </select>
      </div>
     <label for="message" class="form-input">
        <div class="absolute top-0 left-0 right-0 px-5 md:px-4 pt-2 pb-2 bg-gray-100 rounded-t-lg border-gray-300 z-10 uppercase par-sm font-semibold">
          <%= t("contact.message") %>
        </div>
        <textarea id="message" name="message" cols="30" rows="10" required class="pt-12"></textarea>
      </label>
      <label for="accept_privacy_policy" class="flex flex-row gap-x-2 items-center hover:cursor-pointer">
        <input type="checkbox" id="accept_privacy_policy" name="accept_privacy_policy" required/>
        <span><%= I18n.t('contact.privacy_policy.accept_prefix') %> <a href="<%= "#{t(:path)}/privacy-policy" %>" class="underline"><%= I18n.t('contact.privacy_policy.accept_link') %></a></span>
      </label>
      <div class="par-sm text-gray-500 prose">
        <%= t('contact.privacy_policy.message') %>
      </div>
      <div class="par-md">
        <button type="submit" class=" w-full sm:w-auto px-4 py-3 justify-center flex items-center text-red-500 bg-white hover:text-red-500 rounded-xl transition outline outline-1 outline-offset-[-1px] hover:outline-0 outline-red-500 hover:bg-red-100"><%= t("contact.send") %></button>
      </div>
    </form>
  </div>
</section>

<%= partial "/partials/cta-banner" %>
