---
nav: features
description:
---

<section>
  <div class="container pt-6 pb-6 md:pt-24 md:pb-12">
    <div class="md:w-3/5 space-y-6">
      <h1 class="h1 md:whitespace-nowrap">
        <%= t("features.title") %>
      </h1>
      <p class="par-xl text-black">
        <%= t("features.subtitle") %>
      </p>
      <div class="par-md text-black space-y-3">
        <%= t("features.intro") %>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container py-6 md:py-12">
    <h3 class="h3">
      <%= t("features.type1.title") %>
    </h3>

    <div class="hidden md:block mt-8 border-gray-100 pb-12" data-tabs="features">
      <ul role="tablist" class="flex items-center space-x-8">
        <% data.features.spaces.each_with_index do |use, i| %>
          <li role="tab" tabindex="0" class="flex items-center space-x-3 py-2 relative par-md text-gray-500 hover:text-red-500 transition cursor-pointer after:content-[''] after:absolute after:rounded-full after:h-2 after:top-full after:hover:bg-red-500 after:w-full after:bg-gray-100 after:transition <%= 'is-selected' if i == 0 %>" data-tab-id="<%= use.id %>">
            <%= icon use.icon, class: "w-5 h-5" %>
            <span class="par-md">
              <%= t("features.page.#{use.id}.title") %>
            </span>
          </li>
        <% end %>
      </ul>
      <% data.features.spaces.each_with_index do |use, i| %>
        <div class="hidden flex flex-col md:flex-row items-stretch md:items-center gap-6 mt-10 <%= 'is-selected' if i == 0 %>" data-tab-content="<%= use.id %>">
          <div class="md:w-3/5">
            <p class="par-lg max-w-prose">
              <%= t("features.page.#{use.id}.subtitle") %>
            </p>
            <p class="par-md text-gray-500 mt-2 max-w-prose">
              <%= t("features.page.#{use.id}.text") %>
            </p>
          </div>
          <div class="md:w-2/5 rounded-xl overflow-hidden bg-gray-300">
            <img class="object-cover w-full aspect-[4/3]" src="<%= use.image %>">
          </div>
        </div>
      <% end %>
    </div>

    <div class="block md:hidden mt-6" data-accordion="features">
      <% data.features.spaces.each_with_index do |use, i| %>
        <details class="group">
          <summary class="flex items-center space-x-3 pt-4 pb-3 relative par-md text-gray-500 hover:text-red-500 group-open:text-red-500 group-open:after:bg-red-500 transition cursor-pointer after:content-[''] after:absolute after:rounded-full after:h-2 after:top-full after:hover:bg-red-500 after:w-full after:bg-gray-100 after:transition">
            <%= icon use.icon, class: "w-5 h-5 no-toggle" %>
            <span class="par-md">
              <%= t("features.page.#{use.id}.title") %>
            </span>
          </summary>
          <div class="flex flex-col md:flex-row items-stretch md:items-center gap-6 group-open:pt-6 pointer-events-none -translate-y-full max-h-0 opacity-0 transition-all">
            <div class="md:w-3/5">
              <p class="par-lg max-w-prose">
                <%= t("features.page.#{use.id}.title") %>&nbsp;<%= t("features.page.#{use.id}.subtitle") %>
              </p>
              <p class="par-md text-gray-500 mt-2 max-w-prose">
                <%= t("features.page.#{use.id}.text") %>
              </p>
            </div>
            <div class="md:w-2/5 rounded-xl overflow-hidden bg-gray-300">
              <img class="object-cover w-full aspect-[4/3]" src="<%= use.image %>">
            </div>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</section>

<section>
  <div class="container py-6 md:py-12">
    <h3 class="h3">
      <%= t("features.type2.title") %>
    </h3>
    <div class="par-md py-3">
      <%= t("features.type2.subtitle") %>
    </div>

    <div class="hidden md:block relative">
      <% %w[components_group_1 components_group_2 components_group_3 components_group_4].each_with_index do |component_key, idx| %>
        <div class="mt-8 relative">
          <div class="mb-6 flex items-start gap-4">
            <div class="relative flex flex-col items-center">
              <span class="rounded-full text-base border items-center border-black bg-transparent flex justify-center w-8 h-8 relative z-10 mt-2.5">
                <%= format("%2d", idx + 1) %>
              </span>
              <% unless idx == 4 %>
                <div class="w-[0.1rem] h-96 bg-black"></div>
              <% end %>
            </div>
            <h4 class="h4 pt-1">
              <%= t("features.component_groups.#{data.features.send(component_key.to_sym).title}") %>
            </h4>
          </div>
          <div class="flex flex-col md:flex-row items-stretch space-y-6 md:space-y-0 md:space-x-6 gap-5 ml-12 -mt-96">
            <% data.features.send(component_key.to_sym).items.each do |use| %>
              <div class="rounded-xl flex-1 bg-gray-100 p-6 flex flex-col justify-start items-start gap-4">
                <%= icon use.icon, class: "w-7 h-7" %>
                <h6 class="h6">
                  <%= I18n.t("features.page.#{use.id}.title") %>
                </h6>
                <p class="par-md max-w-prose first-letter:uppercase">
                  <%= I18n.t("features.page.#{use.id}.subtitle") %>
                </p>
                <p class="mt-auto max-w-prose text-black">
                  <%= I18n.t("features.page.#{use.id}.text") %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="block md:hidden relative" data-accordion="components">
      <% %w[components_group_1 components_group_2 components_group_3 components_group_4].each_with_index do |component_key, idx| %>
        <div class="relative">
          <details class="group relative">
            <summary class="flex items-center space-x-3 py-4 relative par-md text-black hover:text-red-500 group-open:text-red-500 transition cursor-pointer after:content-[''] after:absolute after:rounded-full after:h-2 after:right-0 after:hover:bg-transparent after:w-full after:bg-transparent after:transition pl-6">
              <span class="absolute left-0 rounded-full border items-center text-base border-black bg-transparent flex justify-center w-8 h-8">
                <%= format("%2d", idx + 1) %>
              </span>
              <span class="par-md pl-2">
                <%= t("features.component_groups.#{data.features.send(component_key.to_sym).title}") %>
              </span>
            </summary>
            <div class="absolute left-4 top-12 bottom-0 w-[0.1rem] bg-black hidden group-open:block"></div>
            <div class="group-open:pt-2 pb-6 pointer-events-none group-open:pointer-events-auto -translate-y-full max-h-0 opacity-0 group-open:translate-y-0 group-open:max-h-none group-open:opacity-100 transition-all">
              <div class="space-y-4 pl-10">
                <% data.features.send(component_key.to_sym).items.each do |use| %>
                  <div class="rounded-xl bg-gray-100 p-4 flex flex-col items-start gap-3">
                    <%= icon use.icon, class: "w-6 h-6" %>
                    <h6 class="h6 text-base">
                      <%= I18n.t("features.page.#{use.id}.title") %>
                    </h6>
                    <p class="par-sm max-w-prose first-letter:uppercase">
                      <%= I18n.t("features.page.#{use.id}.subtitle") %>
                    </p>
                    <p class="text-sm max-w-prose text-black">
                      <%= I18n.t("features.page.#{use.id}.text") %>
                    </p>
                  </div>
                <% end %>
              </div>
            </div>
          </details>
          <% unless idx == 3 %>
            <div class="absolute left-4 -bottom-3 w-[0.1rem] h-[1.6rem] bg-black"></div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-red-100 mt-12 py-12 md:py-16">
  <div class="container space-y-6">
    <h2 class="h2 text-red-500">
      <%= t("features.section4.title") %>
    </h2>
    <div class="inline-flex flex-col md:flex-row gap-4 par-md">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("features.section4.link"), url: "https://try.decidim.org/" } %>
    </div>
  </div>
</section>

<section class="container py-12 flex flex-col md:flex-row items-stretch space-y-6 md:space-y-0 md:space-x-6 gap-5">
  <div class="flex flex-col space-y-6 p-8 bg-gray-100 rounded-xl">
    <h2 class=" text-black text-5xl font-light">
      <%= t("features.modules.title") %>
    </h2>
    <div class="flex-1">
      <p class="par-lg max-w-prose text-black">
        <%= t("features.modules.intro") %>
      </p>
       <p class="par-lg max-w-prose text-black">
        <%= t("features.modules.subtitle") %>
      </p>
    </div>
    <span class="flex flex-col md:flex-row gap-4 par-md mt-auto">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("features.modules.button"), url: "https://docs.decidim.org/en/develop/install/", classes: "text-black", outline_classes: "outline-black", hover_bg_classes: "hover:bg-white", icon_name: "ri-external-link-line" } %>
    </span>
  </div>
  <div class="flex flex-col space-y-6 p-8 bg-gray-100 rounded-xl">
    <h2 class=" text-black text-5xl font-light">
      <%= t("features.need_help.title") %>
    </h2>
    <div class="flex-1">
      <p class="par-lg max-w-prose text-black">
        <%= t("features.need_help.subtitle") %>
      </p>
    </div>
    <span class="flex flex-col md:flex-row gap-4 par-md mt-auto">
      <%= partial "partials/arrow-link-rounded", locals: { text: t("features.need_help.button"), url: "#{t(:path)}/partners", classes: "text-black", outline_classes: "outline-black", hover_bg_classes: "hover:bg-white" } %>
    </span>
  </div>
</section>
<%= partial "/partials/cta-banner" %>
